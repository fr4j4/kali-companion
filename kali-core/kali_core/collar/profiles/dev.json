{
  "id": "dev",
  "name": "Development",
  "description": "Profile for coding sessions. Whitelists common dev actions.",
  "allowed_tools": ["fs_read", "fs_list", "run_tests", "git_worktree", "git_diff", "launch_app", "list_monitors", "screenshot"],
