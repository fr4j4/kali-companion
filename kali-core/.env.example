# Kali companion — example configuration.
#
# Copy to `.env` and edit. All values can also be set as real environment
# variables (they take precedence).

# ── Server ───────────────────────────────────────────────
KALI_PORT=8900
# Bind to 0.0.0.0 for LAN / Tailnet access. Set to 127.0.0.1 for local-only.
KALI_HOST=0.0.0.0

# ── LLM (kali-mind) ───────────────────────────────────────
# Provider: "direct" (OpenAI-compatible) or "nanobot" (wraps nanobot WS).
KALI_LLM_PROVIDER=direct

# OpenAI-compatible endpoint. Works with:
#   - Ollama Cloud:    https://<your-ollama-cloud-host>/v1
#   - OpenRouter:      https://openrouter.ai/api/v1
#   - OpenAI:          https://api.openai.com/v1
#   - Local Ollama:    http://localhost:11434/v1
KALI_LLM_API_URL=https://api.openai.com/v1
KALI_LLM_API_KEY=sk-your-key-here
KALI_LLM_MODEL=gpt-4o-mini

# System prompt (the assistant's persona).
KALI_LLM_SYSTEM_PROMPT=You are Kali, a helpful desktop companion. Reply in the user's language.

# ── Nanobot (optional, only if KALI_LLM_PROVIDER=nanobot) ──
KALI_NANOBOT_WS_URL=ws://127.0.0.1:8765
KALI_NANOBOT_API_URL=http://127.0.0.1:8765
KALI_NANOBOT_TOKEN=

# ── TTS (kali-voice) ───────────────────────────────────────
# Provider: "inproc" (Piper in-process) or "http" (external TTS service).
KALI_TTS_PROVIDER=inproc
KALI_TTS_VOICE=glados-es
KALI_TTS_MODE=normal
KALI_TTS_MAX_LENGTH=2000
# Set to false to disable TTS entirely (no synthesis, no audio).
KALI_TTS_ENABLED=true

# Only used if KALI_TTS_PROVIDER=http. Must expose /v1/text-to-speech/<voice>.
KALI_TTS_HTTP_URL=http://localhost:3000

# ── STT (kali-ear) ────────────────────────────────────────
KALI_STT_MODEL=vosk-model-small-es-0.42
KALI_STT_MODEL_EN=vosk-model-small-en-us-0.15
KALI_STT_LANGUAGE=es
KALI_STT_WAKE_WORD=false
KALI_STT_WAKE_WORD_THRESHOLD=0.3
KALI_STT_WAKE_WORD_COOLDOWN=2.0

# ── Web tools (kali-claws) ────────────────────────────────
KALI_SEARXNG_URL=http://127.0.0.1:8080

# ── Permissions (kali-collar) ──────────────────────────────
KALI_PROFILE=dev